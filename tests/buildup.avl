function Compute_TC(Graph g) {
int triangle_count=0;
# triangle_count = triangle_count + 1;
# triangle_count += 1;
# triangle_count=0;
forall(v in g.nodes()) {
# int triangle_count;
  forall(u in g.neighbors(v).filter(u < v)) {
    forall(w in g.neighbors(v).filter(w > v)) {
      if (g.is_an_edge(u, w)) {
        triangle_count += 1;
      }
    }
  }
}
  return triangle_count;
  # return 0;
}
